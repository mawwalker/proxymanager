{
  "name": "proxymanager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker proxy and subscription manager",
  "scripts": {
    "dev": "XDG_CONFIG_HOME=.wrangler-home wrangler dev",
    "build:ui": "vite build",
    "build": "npm run build:ui && XDG_CONFIG_HOME=.wrangler-home wrangler deploy --dry-run --outdir .wrangler-dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cloudflare-workers",
    "proxy",
    "subscription"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.12.27",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260624.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
